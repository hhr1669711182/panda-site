# MongoDB 连接字符串
DATABASE_URL="mongodb://localhost:27017/panda-site"
# 或使用 MongoDB Atlas:
# DATABASE_URL="mongodb+srv://<user>:<password>@cluster.mongodb.net/panda-site"

# JWT 密钥 (随机32位字符串)
JWT_SECRET="your-super-secret-jwt-key-change-this"

# JWT 过期时间
JWT_EXPIRES_IN="7d"

# 媒体文件存储目录
UPLOAD_DIR="./public/uploads"

# 后台管理跨域白名单
ADMIN_ORIGIN="http://localhost:5173"

# 网站基础 URL (用于 SEO sitemap)
NUXT_PUBLIC_SITE_URL="http://localhost:3000"
